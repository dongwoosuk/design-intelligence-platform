# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local to version control!

# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API Key (OPTIONAL - for AI description generation)
# Get your API key from: https://aistudio.google.com/app/apikey
# Leave empty if you don't need AI descriptions
GEMINI_API_KEY=

# Note: Embedding is now handled locally using transformers.js (all-MiniLM-L6-v2)
# No external API key required for semantic search!

# Autodesk Platform Services (APS) Configuration
# Required for ACC (Autodesk Construction Cloud) integration
# Get your credentials from: https://aps.autodesk.com/myapps
APS_CLIENT_ID=your-client-id-here
APS_CLIENT_SECRET=your-client-secret-here
APS_CALLBACK_URL=http://localhost:4000/api/callback/autodesk
